# MacOS
.DS_Store

# Environment files
.env
.env.*

# Node
node_modules/

# Python
__pycache__/

# VS Code
.vscode/

# Logs
*.log

# Temporary files
*.tmp
*.temp

# Office lock/owner files
~$*

# Outputs — keep the folder structure, ignore the generated commercial output
outputs/drafts/*
outputs/final/*
outputs/account-plans/*
outputs/archive/*

!outputs/drafts/.gitkeep
!outputs/final/.gitkeep
!outputs/account-plans/.gitkeep
!outputs/archive/.gitkeep
